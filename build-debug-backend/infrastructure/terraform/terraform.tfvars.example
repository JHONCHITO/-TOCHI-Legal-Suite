image             = "ghcr.io/your-org/tochi-legal-suite:latest"
mongodb_uri       = "mongodb+srv://user:password@cluster.example.mongodb.net/tochi"
nextauth_url      = "https://tochi.example.com"
auth_secret       = "replace-with-a-long-random-secret"
openai_api_key    = "replace-with-openai-key"
public_app_url    = "https://tochi.example.com"
host              = "tochi.example.com"
tls_secret_name   = "tochi-legal-suite-tls"
ingress_class_name = "nginx"
